def train_iqa_model_with_repeats(dataset_name, n_repeats=5, manual_split_seeds=None):
    """主训练函数 - 执行5次重复实验，手动设置数据划分种子"""

    print(f"\n{'#' * 80}")
    print(f"STARTING {n_repeats} REPEATED EXPERIMENTS FOR DATASET: {dataset_name}")
    print(f"{'#' * 80}")

    # 获取配置
    config = DatasetConfig.get_config(dataset_name)

    # 创建主输出目录
    main_output_dir = os.path.join(config['OUTPUT_DIR'], f"{dataset_name}_repeats")
    os.makedirs(main_output_dir, exist_ok=True)

    # 1. 解析数据集 (只运行一次)
    parser_method = getattr(DatasetParser, config['parser'])
    paths, scores, extra_info = parser_method(config)
    if not paths:
        print(f"No data found for {dataset_name}. Please check the dataset path.")
        return

    # 2. 缓存显著性图 (只运行一次)
    print("\n" + "=" * 30 + " Generating/Caching Saliency Maps ONCE " + "=" * 30)
    sal_cache_dir = os.path.join(main_output_dir, f"global_sal_cache_{config['BASE_SIZE']}")
    sal_cache = cache_saliency(
        paths,
        sal_cache_dir,
        config['DEVICE'],
        config['BASE_SIZE']
    )
    print("=" * 80 + "\n")

    # -------------------------------------------------------------
    # 3. 核心修改：设置固定训练种子和手动设置的划分种子
    # -------------------------------------------------------------
    # 设置固定的训练种子，用于模型初始化、数据加载顺序等。
    TRAINING_SEED = 142
    print(f"Set fixed TRAINING_SEED for model initialization/training: {TRAINING_SEED}")

    # 使用手动设置的划分种子
    if manual_split_seeds is None or len(manual_split_seeds) != n_repeats:
        print(f"WARNING: manual_split_seeds not provided or length is not {n_repeats}. Using default generated seeds.")
        # 如果未手动设置或数量不对，使用默认生成方式
        MANUAL_SPLIT_SEEDS = [100 + i * 20 for i in range(n_repeats)]
    else:
        MANUAL_SPLIT_SEEDS = manual_split_seeds

    print(f"Using MANUAL_SPLIT_SEEDS for data partitioning: {MANUAL_SPLIT_SEEDS}")
    # -------------------------------------------------------------

    # 存储每次实验的结果
    srcc_results = []
    plcc_results = []
    all_predictions = []
    all_ground_truth = []

    # 执行多次重复实验
    for i in range(n_repeats):
        split_seed = MANUAL_SPLIT_SEEDS[i]

        # 在每次实验开始时，设置固定的训练种子，确保模型初始化、权重随机性、DataLoader shuffle 顺序一致。
        set_seed(TRAINING_SEED)
        print(f"\n--- Setting TRAINING_SEED ({TRAINING_SEED}) before experiment {i + 1} ---")

        # 执行单次实验 (传入预先解析的数据和划分种子)
        test_srcc, test_plcc, predictions, ground_truth = train_single_experiment(
            dataset_name, split_seed, i, paths, scores, extra_info, sal_cache
        )

        if test_srcc is not None and test_plcc is not None:
            srcc_results.append(test_srcc)
            plcc_results.append(test_plcc)
            all_predictions.append(predictions)
            all_ground_truth.append(ground_truth)

    # 分析实验结果
    if srcc_results and plcc_results:
        srcc_mean, srcc_margin, plcc_mean, plcc_margin = analyze_experiment_results(
            dataset_name, srcc_results, plcc_results, all_predictions, all_ground_truth, main_output_dir
        )

        # 输出最终结果（模拟论文中的表格格式）
        print(f"\n{'=' * 80}")
        print(f"FINAL RESULTS FOR {dataset_name} (Fixed Training Seed: {TRAINING_SEED})")
        print(f"{'=' * 80}")
        print(f"SRCC: {srcc_mean:.4f} ± {srcc_margin:.4f} (95% CI)")
        print(f"PLCC: {plcc_mean:.4f} ± {plcc_margin:.4f} (95% CI)")
        print(f"{'=' * 80}")

        # 保存最终摘要
        with open(os.path.join(main_output_dir, f"final_summary_{dataset_name}.txt"), "w") as f:
            f.write(f"Final Results for {dataset_name} ({n_repeats} repeats)\n")
            f.write(f"Fixed Training Seed: {TRAINING_SEED}\n")
            f.write(f"Split Seeds Used: {MANUAL_SPLIT_SEEDS}\n")
            f.write("=" * 50 + "\n\n")
            f.write(f"SRCC: {srcc_mean:.4f} ± {srcc_margin:.4f}\n")
            f.write(f"PLCC: {plcc_mean:.4f} ± {plcc_margin:.4f}\n\n")
            f.write(f"95% Confidence Intervals:\n")
            f.write(f"  SRCC: [{srcc_mean - srcc_margin:.4f}, {srcc_mean + srcc_margin:.4f}]\n")
            f.write(f"  PLCC: [{plcc_mean - plcc_margin:.4f}, {plcc_mean + plcc_margin:.4f}]\n")

    else:
        print(f"ERROR: No valid results obtained for {dataset_name}")

    print(f"\n{'#' * 80}")
    print(f"ALL EXPERIMENTS COMPLETED FOR {dataset_name}")
    print(f"{'#' * 80}")


